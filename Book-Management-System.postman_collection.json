          "mode": "formdata",
          "formdata": [
            {
              "key": "book",
              "value": "{\n  \"title\": \"Effective Java\",\n  \"author\": \"Joshua Bloch\",\n  \"isbn\": \"9780134685991\",\n  \"publisher\": \"Addison-Wesley\",\n  \"genre\": \"Programming\",\n  \"price\": 45.99,\n  \"quantity\": 10,\n  \"description\": \"Best practices for the Java platform.\"\n}",
              "type": "text"
            },
            {
              "key": "image",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api", "books"] }
      }
    },
    {
      "name": "Get All Books",
      "request": {
        "method": "GET",
        "header": [],
