          "formdata": [
            {
              "key": "book",
              "value": "{\n  \"title\": \"Effective Java (3rd Edition)\",\n  \"author\": \"Joshua Bloch\",\n  \"isbn\": \"9780134685991\",\n  \"publisher\": \"Addison-Wesley\",\n  \"genre\": \"Programming\",\n  \"price\": 49.99,\n  \"quantity\": 8,\n  \"description\": \"Updated description.\"\n}",
              "type": "text"
            },
            {
              "key": "image",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": { "raw": "{{baseUrl}}/api/books/1", "host": ["{{baseUrl}}"], "path": ["api", "books", "1"] }
      }
    },
    {
